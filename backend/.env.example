# IBM watsonx.ai
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-4-h-small

# IBM Watson Natural Language Understanding
WATSON_NLU_API_KEY=
WATSON_NLU_URL=https://api.us-south.natural-language-understanding.watson.cloud.ibm.com

# Application
DATABASE_URL=sqlite+aiosqlite:///./storyglide.db

# Set to "true" to use stub responses instead of live IBM API calls (for local dev/CI)
MOCK_AI=false
